include ../includes/shared-mixins.pug

if (!utxoSetSummary)
	.mt-3
		.alert.alert-warning.mb-0
			p.mb-2.fw-bold UTXO Set summary is not available.
			p.mb-2 The Namecoin/Bitcoin Core RPC `gettxoutsetinfo` either errored, timed out, or returned an unexpected shape. Common causes:
			ul.mb-2
				li The node does not have <code>coinstatsindex=1</code> enabled, so each call has to scan the chainstate (slow on Namecoin — typically 60–120s on commodity hardware). Browser AJAX often gives up before the response arrives.
				li The explorer is running with <code>BTCEXP_SLOW_DEVICE_MODE=true</code> (the default), which intentionally skips this RPC at startup.
			p.mb-0 Recommended fix: enable <code>coinstatsindex=1</code> in <code>namecoin.conf</code> and restart <code>namecoind</code> (one-time index build, then sub-second responses), then set <code>BTCEXP_SLOW_DEVICE_MODE=false</code> in the explorer .env and restart the explorer.
else
	.mt-3
		+pageTabs(["Details", "JSON"])


		div.tab-content
			+pageTab("Details", true)
				+contentSection
					+summaryRow(3)
						+summaryItem("Last Updated", "The time this UTXO Set snapshot was produced")
							+timestamp(utxoSetSummary.lastUpdated / 1000)

						+summaryItem("Block Height", "The top block height at the time this UTXO Set snapshot was produced")
							a(href=`./block-height/${utxoSetSummary.height}`) #{utxoSetSummary.height.toLocaleString()}

						+summaryItem("Block Hash", "The top block hash at the time this UTXO Set snapshot was produced")
							a(href=`./block/${utxoSetSummary.bestblock}`) #{utils.ellipsizeMiddle(utxoSetSummary.bestblock, 12)}
							+copyTextButton(utxoSetSummary.bestblock)
					
					hr.mt-3.mb-3
					
					+summaryRow(2 + (utxoSetSummary.transactions ? 1 : 0) + (utxoSetSummary.disk_size ? 1 : 0) + (utxoSetSummary.total_unspendable_amount ? 1 : 0))
						+summaryItem("UTXO Count", "The total number of UTXOs, or Unspent Transaction Outputs, across the entire blockchain")
							| #{utxoSetSummary.txouts.toLocaleString()}

						+summaryItem("Coins", "The sum of all spendable NMC units across the entire blockchain")
							span #{parseFloat(utxoSetSummary.total_amount).toLocaleString()}
							+copyTextButton(utxoSetSummary.total_amount)

						if (utxoSetSummary.transactions)
							+summaryItem("Total Transactions", "The total number of transactions that have unspent outputs")
								| #{utxoSetSummary.transactions.toLocaleString()}

						if (utxoSetSummary.total_unspendable_amount)
							+summaryItem("Unspendable Coins", "The total amount of coins permanently excluded from the UTXO Set (only available if coinstatsindex is used)")
								span #{parseFloat(utxoSetSummary.total_unspendable_amount).toLocaleString()}

						if (utxoSetSummary.disk_size)
							+summaryItem("Disk Size", "The estimated size of the UTXO Set on disk")
								- var diskSize = utils.formatLargeNumber(utxoSetSummary.disk_size);

								| #{new Decimal(diskSize[0]).toDP(3)} #{diskSize[1].abbreviation}B

					// Namecoin-only breakdown: the UTXO total split into the
					// currency and the name halves, plus a count of how many names
					// are actually registered on chain (separate from the locked NMC).
					if (utxoSetSummary.total_coins_amount !== undefined || utxoSetSummary.total_names_amount !== undefined || namesSummary || namesSummaryPending)
						hr.mt-3.mb-3
						.mb-3
							h6.text-card-highlight.fw-light.text-uppercase Namecoin breakdown
							.text-muted.small Two distinct metrics are easy to confuse: the count of names on chain, and the NMC locked inside name outputs.
						- var __nameCells = (utxoSetSummary.total_coins_amount !== undefined ? 1 : 0) + (utxoSetSummary.total_names_amount !== undefined ? 1 : 0) + ((namesSummary || namesSummaryPending) ? 1 : 0)
						+summaryRow(Math.max(__nameCells, 1))
							if (utxoSetSummary.total_coins_amount !== undefined)
								+summaryItem("Coins (currency NMC)", "NMC sitting in plain currency outputs. This is the spendable money supply outside of name registrations — transferring this is a normal currency tx and does not touch the name database.")
									span #{parseFloat(utxoSetSummary.total_coins_amount).toLocaleString()}
									span.text-muted.small.ms-1 NMC
							if (utxoSetSummary.total_names_amount !== undefined)
								+summaryItem("NMC locked in names", "Sum of NMC sitting inside name outputs at the chain tip. Every registered name carries a small NMC balance (typically 0.01 NMC, but it has varied) that follows the name UTXO around until the name expires. This is NOT a count of names — it's the NMC value bound up in them.")
									span #{parseFloat(utxoSetSummary.total_names_amount).toLocaleString()}
									span.text-muted.small.ms-1 NMC
							if (namesSummary)
								+summaryItem("Registered names", "Count of unique names returned by Namecoin Core's `name_scan`. \"Active\" = unexpired (still resolvable). \"Total\" includes expired-but-not-yet-pruned entries that still live in the name database.")
									span #{namesSummary.active.toLocaleString()}
									span.text-muted.small.ms-1 active
									div.small.text-muted.mt-1
										span= namesSummary.total.toLocaleString()
										span.ms-1 total
										if (namesSummary.expired)
											span.ms-1 (#{namesSummary.expired.toLocaleString()} expired)
									if (namesSummary.truncated)
										div.small.text-warning.mt-1 (truncated — hit per-prefix scan cap)
							else if (namesSummaryPending)
								+summaryItem("Registered names", "Count of unique names returned by Namecoin Core's name_scan.")
									span.text-muted …
									div.small.text-muted.mt-1 Computing in background
						if (namesSummary && namesSummary.filterCounts)
							mixin filterTile(__f)
								- var __c = namesSummary.filterCounts[__f.key] || 0
								.col
									a.text-decoration-none.d-block.h-100.p-3.rounded-2.border.border-card-highlight.text-body(href=`./names/filter/${__f.key}`, title=__f.title || "", data-bs-toggle=__f.title ? "tooltip" : null, data-bs-html="true")
										div.small.text-muted= __f.label
										div.h5.fw-light.mb-0.mt-1
											span= __c.toLocaleString()
										if (__c > 0 && namesSummary.active)
											div.small.text-muted #{((__c / namesSummary.active) * 100).toFixed(1)}% of active
							.mt-3
								div.text-muted.small.text-uppercase.mb-2
									span Value-shape filters
									span.ms-2.border-dotted(title="Counts of <em>active</em> names whose value carries each shape (valid JSON, .onion, TLSA records, IP addresses, Nostr identity, I2P address). Click any tile to see the matching names. Lists are sourced from the same 30-min background <code>name_scan</code> walk as the by-namespace breakdown above; per-filter lists are capped at 5,000 entries.", data-bs-toggle="tooltip", data-bs-html="true") (?)
								.row.row-cols-2.row-cols-md-3.row-cols-lg-6.g-2
									- var __filtersValue = [{key:"json",label:"Valid JSON",title:"Names whose value parses as JSON."},{key:"onion",label:".onion",title:"Names with a Tor v2/v3 onion address (<code>tor</code>/<code>_tor</code> field, or any <code>.onion</code> embedded in the value)."},{key:"tls",label:"TLSA",title:"Names that publish TLSA records (ifa-0001 §tls). Used for DANE TLS pinning, e.g. .bit relays."},{key:"ip",label:"IP addresses",title:"Names that publish at least one IP address (any of: <code>ip</code>, <code>ip4</code>, <code>ip6</code>, or a literal address in any string)."},{key:"nostr",label:"Nostr",title:"Names that publish a Nostr identity (single <code>nostr.pubkey</code> or multi-identity <code>nostr.names</code> map)."},{key:"i2p",label:"I2P",title:"Names that publish an I2P address (<code>i2p</code> field or <code>.b32.i2p</code> host)."}]
									each __f in __filtersValue
										+filterTile(__f)
							.mt-4
								div.text-muted.small.text-uppercase.mb-2
									span DNS record filters
									span.ms-2.border-dotted(title="Counts of <em>active</em> names that publish each DNS record type via ifa-0001 §map fields. Click any tile to see matching names. <ul class='mb-0 mt-2 ps-3 small'><li><b>A</b> — IPv4 (<code>ip</code> field)</li><li><b>AAAA</b> — IPv6 (<code>ip6</code> field)</li><li><b>CNAME</b> — alias (<code>alias</code>/<code>translate</code>)</li><li><b>NS</b> — nameserver delegation (<code>ns</code>)</li><li><b>MX</b> — mail exchange (<code>email</code>/<code>mx</code>)</li><li><b>TXT</b> — text records (<code>txt</code>)</li><li><b>SRV</b> — service location (<code>service</code>)</li><li><b>SOA</b> — start of authority (<code>soa</code>)</li><li><b>DS</b> — DNSSEC delegation signer (<code>ds</code>)</li><li><b>DNSSEC</b> — cryptographic validation (<code>dnssec</code>, <code>rrsig</code>, <code>dnskey</code>, <code>nsec</code>, <code>nsec3</code>, <code>ds</code>)</li></ul>", data-bs-toggle="tooltip", data-bs-html="true") (?)
								.row.row-cols-2.row-cols-md-3.row-cols-lg-5.g-2
									- var __filtersDns = [{key:"a",label:"A (IPv4)",title:"<b>A</b> — IPv4 address mapping. Names with <code>ip</code> field or any literal IPv4 in the value."},{key:"aaaa",label:"AAAA (IPv6)",title:"<b>AAAA</b> — IPv6 address mapping. Names with <code>ip6</code> field or any literal IPv6 in the value."},{key:"cname",label:"CNAME",title:"<b>CNAME</b> — Canonical name alias. Names with <code>alias</code> or <code>translate</code> field redirecting to another name."},{key:"ns",label:"NS",title:"<b>NS</b> — Nameserver delegation. Names with <code>ns</code> field delegating resolution authority."},{key:"mx",label:"MX",title:"<b>MX</b> — Mail exchange. Names with <code>email</code> shorthand or <code>mx</code> array."},{key:"txt",label:"TXT",title:"<b>TXT</b> — Text records. Names with <code>txt</code> field carrying arbitrary data (SPF, DKIM, verification, ad-hoc metadata)."},{key:"srv",label:"SRV",title:"<b>SRV</b> — Service location. Names with <code>service</code> field locating host:port for named services."},{key:"soa",label:"SOA",title:"<b>SOA</b> — Start of authority. Names with <code>soa</code> field declaring DNS zone authority."},{key:"ds",label:"DS",title:"<b>DS</b> — Delegation signer (DNSSEC). Names with <code>ds</code> field anchoring DNSSEC validation for a child zone."},{key:"dnssec",label:"DNSSEC",title:"<b>DNSSEC</b> — Cryptographic validation marker. Names with any of: <code>dnssec</code>, <code>rrsig</code>, <code>dnskey</code>, <code>nsec</code>, <code>nsec3</code>, or <code>ds</code> field."}]
									each __f in __filtersDns
										+filterTile(__f)

						if (namesSummary && namesSummary.byNamespace && Object.keys(namesSummary.byNamespace).length)
							.mt-3
								div.text-muted.small.text-uppercase.mb-2
									span By namespace
									span.ms-2.border-dotted(title="Counts of names registered under each top-level namespace prefix (the part before the first <code>/</code>). <b>Active</b> names are still resolvable; <b>Expired</b> names live in the index but no longer resolve. Sourced from the same 30-min background <code>name_scan</code> walk.", data-bs-toggle="tooltip", data-bs-html="true") (?)
								.table-responsive
									table.table.table-sm.table-borderless.mb-0.small
										thead
											tr
												th.text-card-highlight.fw-light.text-uppercase NS
												th.text-end.text-card-highlight.fw-light.text-uppercase Active
												th.text-end.text-card-highlight.fw-light.text-uppercase Expired
												th.text-end.text-card-highlight.fw-light.text-uppercase Total
												th.d-none.d-md-table-cell.text-card-highlight.fw-light.text-uppercase Description
										tbody
											- var __nsKeys = Object.keys(namesSummary.byNamespace).sort((a,b) => namesSummary.byNamespace[b].active - namesSummary.byNamespace[a].active)
											each __ns in __nsKeys
												- var __row = namesSummary.byNamespace[__ns]
												tr
													td.font-monospace= __ns === "(none)" ? "—" : (__ns + "/")
													td.text-end= __row.active.toLocaleString()
													td.text-end.text-muted= __row.expired.toLocaleString()
													td.text-end= __row.total.toLocaleString()
													td.d-none.d-md-table-cell.text-muted.small= __ns === "(none)" ? "" : (nameApi && nameApi.namespaceLabel ? (nameApi.namespaceLabel(__ns) || "") : "")

						// Squatter leaderboards: groups of names that share an exact
						// identical value. The largest cluster of active names is the
						// "biggest current squatter"; the largest cluster across
						// active+expired is the "biggest all-time squatter".
						mixin squatterTable(__rows, __mode)
							.table-responsive
								table.table.table-sm.table-borderless.mb-0.small
									thead
										tr
											th.text-card-highlight.fw-light.text-uppercase Rank
											th.text-card-highlight.fw-light.text-uppercase Shared value
											if (__mode === "current")
												th.text-end.text-card-highlight.fw-light.text-uppercase Active
												th.text-end.text-card-highlight.fw-light.text-uppercase Total
											else
												th.text-end.text-card-highlight.fw-light.text-uppercase Total
												th.text-end.text-card-highlight.fw-light.text-uppercase Active
												th.text-end.text-card-highlight.fw-light.text-uppercase Expired
											th.text-card-highlight.fw-light.text-uppercase.d-none.d-lg-table-cell Sample names
									tbody
										each __c, __i in __rows
											- var __preview = utils.ellipsize(__c.value.replace(/\s+/g, " ").trim(), 80)
											tr
												td.text-muted= "#" + (__i + 1)
												td
													code.small.text-break(title=__c.value.length > 80 ? __c.value : null, data-bs-toggle=__c.value.length > 80 ? "tooltip" : null)= __preview
													div.small.text-muted.mt-1
														span #{__c.valueLength.toLocaleString()} bytes
														- var __nsKeys = Object.keys(__c.byNamespace).sort((a,b) => __c.byNamespace[b] - __c.byNamespace[a])
														if (__nsKeys.length)
															span.ms-2.text-muted across #{__nsKeys.length} namespace#{__nsKeys.length === 1 ? "" : "s"}:
															each __ns in __nsKeys.slice(0, 4)
																span.ms-1.font-monospace.text-muted #{__ns === "(none)" ? "—" : __ns + "/"} #{__c.byNamespace[__ns].toLocaleString()}
															if (__nsKeys.length > 4)
																span.ms-1.text-muted +#{__nsKeys.length - 4} more
												if (__mode === "current")
													td.text-end.fw-bold= __c.activeCount.toLocaleString()
													td.text-end.text-muted= __c.count.toLocaleString()
												else
													td.text-end.fw-bold= __c.count.toLocaleString()
													td.text-end= __c.activeCount.toLocaleString()
													td.text-end.text-muted= __c.expiredCount.toLocaleString()
												td.d-none.d-lg-table-cell.small.font-monospace.text-muted
													- var __sampleCount = (__c.sampleNames || []).length
													each __n, __si in __c.sampleNames
														a.text-muted(href=`./name/${encodeURIComponent(__n)}`)= __n
														if (__si < __sampleCount - 1)
															| , 

						if (namesSummary && namesSummary.squattersCurrent && namesSummary.squattersCurrent.length)
							.mt-4
								div.text-muted.small.text-uppercase.mb-2
									span Biggest current squatter
									span.ms-2.border-dotted(title="Groups of <em>currently active</em> names whose value is byte-for-byte identical. Bulk registrations from a single operator (typo-squat farms, parking pages, drainer farms, IPFS gateways, sinkholes, mass-mirrored content) almost always reuse one template value across thousands of names — the largest such cluster is the biggest current squatter on chain. <br><br><b>How calculated:</b> during the same 30-min background <code>name_scan</code> walk that powers the by-namespace and value-shape sections, every active name's exact value string is hashed into a bucket; clusters with at least #{namesSummary.squatterMinCount || 2} active names are ranked, top #{namesSummary.squatterTopN || 10} shown. Empty values (newly-registered <code>name_new</code> placeholders) are skipped. Ties are broken by total (active+expired) cluster size.", data-bs-toggle="tooltip", data-bs-html="true") (?)
								+squatterTable(namesSummary.squattersCurrent, "current")

						if (namesSummary && namesSummary.squattersAllTime && namesSummary.squattersAllTime.length)
							.mt-4
								div.text-muted.small.text-uppercase.mb-2
									span Biggest all-time squatter
									span.ms-2.border-dotted(title="Groups of names whose value is byte-for-byte identical, this time counting <em>both active and expired</em> names — the all-time scope mirrors the Active+Expired+Total columns of the <em>By namespace</em> section above. Captures squatter farms whose registrations have lapsed but still live in the name database. <br><br><b>How calculated:</b> same per-value bucketing as <em>Biggest current squatter</em>, but ranked by <em>total</em> cluster size (active + expired) instead of just active. Clusters with at least #{namesSummary.squatterMinCount || 2} names are ranked, top #{namesSummary.squatterTopN || 10} shown. Empty values are skipped. Ties are broken by active count.", data-bs-toggle="tooltip", data-bs-html="true") (?)
								+squatterTable(namesSummary.squattersAllTime, "alltime")

				if (utxoSetSummary.usingCoinStatsIndex)
					span.small.text-muted Note: The above UTXO Set snapshot was produced using this node's <b>coin-stats index</b>; using this index affects which properties are available. Comparing the data above to a UTXO Set snapshot produced on a node without the coin-stats index enabled will look slightly different.

				else
					span.small.text-muted Note: This node does not have the <b>coin-stats index</b> enabled so this UTXO Set snapshot was built without it. Comparing the data above to a UTXO Set snapshot produced on a node WITH the coin-stats index enabled will look slightly different.


			+pageTab("JSON", false)
				+contentSection
					pre
						code.json #{JSON.stringify(utxoSetSummary, null, 4)}